<!doctype html>
<html lang="en" class="{{ state.theme if state else 'dark' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{% block title %}AI Agent Chatbot{% endblock %}</title>
    <script src="https://unpkg.com/htmx.org@1.11.1"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="/static/style.css" rel="stylesheet">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['Outfit', 'Inter', 'system-ui', 'sans-serif'],
              mono: ['JetBrains Mono', 'monospace'],
            },
            colors: {
              primary: {
                 DEFAULT: '#0ea5e9',
                 50: '#f0f9ff',
                 100: '#e0f2fe',
                 200: '#bae6fd',
                 300: '#7dd3fc',
                 400: '#38bdf8',
                 500: '#0ea5e9',
                 600: '#0284c7',
                 700: '#0369a1',
              },
              secondary: {
                 DEFAULT: '#818cf8',
                 50: '#eef2ff',
                 100: '#e0e7ff',
                 200: '#c7d2fe',
                 300: '#a5b4fc',
                 400: '#818cf8',
                 500: '#6366f1',
                 600: '#4f46e5',
              },
              accent: '#f59e0b',
              success: '#10b981',
              danger: '#ef4444',
              dark: {
                DEFAULT: '#020617', // Midnight Slate
                50: '#0f172a',      // Surface Slate
                100: '#1e293b',     // Card Slate
                200: '#334155',     // Border Slate
                300: '#475569',
              },
              light: {
                DEFAULT: '#f8fafc',
                50: '#f1f5f9',
                100: '#e2e8f0',
                200: '#cbd5e1',
              }
            },
            boxShadow: {
                'glow': '0 0 20px rgba(14, 165, 233, 0.4)',
                'premium': '0 10px 40px -10px rgba(0, 0, 0, 0.3)',
            }
          }
        }
      }
    </script>
  </head>
  <body class="dark:bg-dark bg-light-50 dark:text-gray-100 text-gray-900 min-h-screen transition-colors duration-300 selection:bg-primary selection:text-white overflow-hidden">
    {% block content %}{% endblock %}
  </body>
</html>

