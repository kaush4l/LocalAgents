<!doctype html>
<html lang="en" class="{{ state.theme if state else 'dark' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{% block title %}AI Agent Chatbot{% endblock %}</title>
    <script src="https://unpkg.com/htmx.org@1.11.1"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              primary: '#0ea5e9',
              secondary: '#8b5cf6',
              accent: '#f59e0b',
              success: '#10b981',
              danger: '#ef4444',
              dark: {
                DEFAULT: '#0f172a',
                50: '#1e293b',
                100: '#334155',
                200: '#475569',
              },
              light: {
                DEFAULT: '#f8fafc',
                50: '#f1f5f9',
                100: '#e2e8f0',
                200: '#cbd5e1',
              }
            }
          }
        }
      }
    </script>
    <style>
      @keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 5px currentColor; opacity: 0.7; }
        50% { box-shadow: 0 0 15px currentColor; opacity: 1; }
      }
      .pulse-glow { animation: pulse-glow 2s infinite; }
      
      @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .spin-slow { animation: spin-slow 3s linear infinite; }
      
      .message-enter {
        animation: slideIn 0.3s ease-out;
      }
      
      @keyframes slideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .fade-in { animation: fadeIn 0.2s ease-out; }
      
      .scrollbar-thin::-webkit-scrollbar { width: 6px; height: 6px; }
      .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
      .dark .scrollbar-thin::-webkit-scrollbar-thumb { background: rgba(14, 165, 233, 0.3); border-radius: 3px; }
      .dark .scrollbar-thin::-webkit-scrollbar-thumb:hover { background: rgba(14, 165, 233, 0.5); }
      .light .scrollbar-thin::-webkit-scrollbar-thumb,
      html:not(.dark) .scrollbar-thin::-webkit-scrollbar-thumb { background: rgba(100, 116, 139, 0.3); border-radius: 3px; }
      
      .glass-dark {
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(14, 165, 233, 0.1);
      }
      .glass-light {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(100, 116, 139, 0.2);
      }
      
      .event-query { border-left-color: #0ea5e9; }
      .event-thought { border-left-color: #8b5cf6; }
      .event-tool_call { border-left-color: #f59e0b; }
      .event-tool_result { border-left-color: #10b981; }
      .event-response { border-left-color: #22c55e; }
      .event-error { border-left-color: #ef4444; }
      .event-system { border-left-color: #64748b; }
      .event-status { border-left-color: #06b6d4; }
      .event-log { border-left-color: #94a3b8; }
      
      .status-idle { color: #64748b; }
      .status-thinking { color: #0ea5e9; }
      .status-executing { color: #f59e0b; }
      .status-completed { color: #10b981; }
      .status-error { color: #ef4444; }
    </style>
  </head>
  <body class="dark:bg-dark bg-light-50 dark:text-gray-100 text-gray-900 min-h-screen transition-colors duration-300">
    {% block content %}{% endblock %}
  </body>
</html>

