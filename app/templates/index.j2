{% extends "base.j2" %}
{% block title %}Alfred - AI Agent Chatbot{% endblock %}
{% block content %}

<div class="flex h-screen overflow-hidden bg-white dark:bg-dark">
  
  <!-- Main Chat Area -->
  <main class="flex-1 flex flex-col min-w-0 relative z-10 bg-white dark:bg-dark">
    <!-- Header -->
    <header class="dark:bg-dark bg-white border-b dark:border-white/5 border-gray-100 px-8 py-5 flex items-center justify-between z-30">
      <div class="flex items-center gap-5">
        <div class="relative">
          <div class="w-12 h-12 rounded-[20px] bg-primary flex items-center justify-center shadow-xl shadow-primary/20">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div class="absolute -top-1 -right-1 w-4 h-4 bg-green-500 rounded-full border-4 dark:border-dark border-white animate-pulse"></div>
        </div>
        <div>
          <h1 class="text-xl font-black dark:text-white text-gray-900 tracking-tight">Alfred</h1>
          <div class="flex items-center gap-2 mt-0.5">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-primary">Core Autonomous</span>
          </div>
        </div>
      </div>
      
      <div class="flex items-center gap-4">
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="w-11 h-11 rounded-2xl dark:bg-dark-50 bg-gray-50 border dark:border-white/5 border-gray-100 flex items-center justify-center text-gray-500 hover:text-primary transition-all hover:scale-105 active:scale-95" title="Toggle theme">
          <svg class="w-5 h-5 dark:hidden block" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
          <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/></svg>
        </button>
        
        <!-- Connection Status -->
        <div id="status-indicator" class="flex items-center gap-3 pl-4 pr-5 py-2.5 rounded-2xl dark:bg-dark-50 bg-gray-50 border dark:border-white/5 border-gray-100">
          <div class="relative">
            <span class="block w-2 h-2 rounded-full bg-gray-400"></span>
          </div>
          <span class="text-[10px] font-black uppercase tracking-widest text-gray-500">Offline</span>
        </div>
      </div>
    </header>

    <!-- Messages Container -->
    <div id="messages" class="flex-1 overflow-y-auto px-6 py-8 space-y-8 scrollbar-custom bg-white dark:bg-dark">
      {% if state and state.messages %}
        {% for msg in state.messages %}
        <div class="message-enter flex {{ 'justify-end' if msg.role == 'user' else 'justify-start' }}">
          <div class="max-w-[85%] lg:max-w-[70%] {{ 'bg-primary shadow-premium text-white' if msg.role == 'user' else 'dark:bg-dark-50 bg-gray-50 dark:text-gray-100 text-gray-900 border dark:border-white/10 border-gray-200 shadow-sm' }} rounded-3xl px-6 py-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[9px] font-black tracking-widest uppercase opacity-60">{{ 'You' if msg.role == 'user' else 'Alfred' }}</span>
            </div>
            <div class="message-content text-[15px] leading-relaxed">
              {{ msg.content | safe }}
            </div>
          </div>
        </div>
        {% endfor %}
      {% else %}
        <div id="welcome-message" class="h-full flex flex-col items-center justify-center text-center fade-in">
          <div class="w-20 h-20 mb-8 rounded-[32px] bg-primary relative flex items-center justify-center shadow-2xl shadow-primary/20">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="text-3xl font-black dark:text-white text-gray-900 tracking-tight mb-4">Hello, I'm Alfred.</h2>
          <p class="dark:text-gray-400 text-gray-500 max-w-sm mx-auto text-[15px] leading-relaxed">Your intelligent assistant for automation, browsing, and more. How can I help you today?</p>
        </div>
      {% endif %}
    </div>

    <!-- Input Area -->
    <footer class="dark:bg-dark-50 bg-white border-t dark:border-white/5 border-gray-200 p-6 relative z-20">
      <div class="max-w-4xl mx-auto">
        <form id="chat-form" class="flex gap-4">
            <div class="flex-1 relative group">
              <div class="absolute -inset-0.5 bg-gradient-to-r from-primary/30 to-secondary/30 rounded-2xl blur opacity-0 group-focus-within:opacity-100 transition duration-500"></div>
              <input
                type="text"
                id="message-input"
                placeholder="Type your instruction..."
                class="w-full relative dark:bg-dark-100/50 bg-gray-50 border dark:border-white/10 border-gray-200 rounded-2xl px-6 py-4 dark:text-gray-100 text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm shadow-sm transition-all"
                autocomplete="off"
              />
            </div>
            
            <button
              type="submit"
              id="send-btn"
              class="px-8 py-4 bg-gradient-to-r from-primary to-secondary rounded-2xl font-bold text-white shadow-lg shadow-primary/20 hover:shadow-primary/40 hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center gap-2 disabled:opacity-50 disabled:grayscale disabled:hover:scale-100"
            >
              <span>Send</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </button>
        </form>
        <div class="text-center mt-4">
             <p class="text-[10px] uppercase tracking-widest font-bold dark:text-gray-600 text-gray-400">ReAct Reasoning Engine</p>
        </div>
      </div>
    </footer>
  </main>

  <!-- Right Sidebar: Events Panel -->
  <aside id="events-panel" class="w-96 flex-shrink-0 dark:bg-dark bg-white border-l dark:border-white/10 border-gray-200 flex flex-col relative z-20">
    <!-- Panel Header -->
    <div class="p-6 border-b dark:border-white/5 border-gray-100 flex items-center justify-between">
      <h2 class="font-bold text-xs uppercase tracking-widest dark:text-gray-400 text-gray-500">Intelligence Stream</h2>
      <div class="flex items-center gap-3">
        <span class="px-2 py-1 rounded-md text-[10px] font-mono dark:text-primary-300 text-primary-600 dark:bg-primary/10 bg-primary/5" id="event-count">{{ state.events | length if state else 0 }} events</span>
        <button id="clear-events" class="p-1.5 rounded-lg hover:bg-danger/10 text-gray-400 hover:text-danger transition-colors" title="Clear log">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </div>
    </div>
    
    <!-- Events Stream -->
    <div id="events-list" class="flex-1 overflow-y-auto scrollbar-custom p-4 space-y-3 dark:bg-dark-50 bg-gray-50/50">
      {% if state and state.events %}
        {% for event in state.events[-50:] %}
        <div class="event-item fade-in p-4 rounded-xl dark:bg-dark-100/50 bg-white border dark:border-white/5 border-gray-200 hover:border-primary/20 transition-all text-sm">
          <div class="flex items-center justify-between mb-2">
            <span class="font-black text-[9px] uppercase tracking-widest
              {% if event.type == 'query' %}text-primary
              {% elif event.type == 'thought' %}text-secondary
              {% elif event.type == 'tool_call' %}text-amber-500
              {% elif event.type == 'tool_result' %}text-success
              {% elif event.type == 'response' %}text-green-500
              {% elif event.type == 'error' %}text-danger
              {% else %}dark:text-gray-500 text-gray-400{% endif %}
            ">
              {% if event.type == 'query' %}Input
              {% elif event.type == 'thought' %}Reasoning
              {% elif event.type == 'tool_call' %}Action
              {% elif event.type == 'tool_result' %}Result
              {% elif event.type == 'response' %}Output
              {% elif event.type == 'error' %}Error
              {% elif event.type == 'status' %}Update
              {% else %}{{ event.type }}{% endif %}
            </span>
            <span class="text-[9px] font-mono opacity-40">{{ event.timestamp[-8:] if event.timestamp else '' }}</span>
          </div>
          <div class="dark:text-gray-300 text-gray-700 text-xs font-mono leading-relaxed break-words whitespace-pre-wrap max-h-32 overflow-hidden">{{ event.content | truncate(300) if event.content is string else event.content | tojson | truncate(300) }}</div>
        </div>
        {% endfor %}
      {% else %}
        <div id="no-events" class="h-full flex flex-col items-center justify-center opacity-30">
           <svg class="w-10 h-10 mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
           <p class="text-xs font-medium uppercase tracking-widest">Awaiting Neural Link</p>
        </div>
      {% endif %}
    </div>
  </aside>
</div>

<!-- Simplified UI Script -->
<script>
  let ws = null;
  let reconnectAttempts = 0;
  const maxReconnectAttempts = 5;

  const messagesContainer = document.getElementById('messages');
  const chatForm = document.getElementById('chat-form');
  const messageInput = document.getElementById('message-input');
  const sendBtn = document.getElementById('send-btn');
  const statusIndicator = document.getElementById('status-indicator');
  const eventsList = document.getElementById('events-list');
  const themeToggle = document.getElementById('theme-toggle');
  const clearEventsBtn = document.getElementById('clear-events');

  let currentAssistantMessage = null;

  function connectWebSocket() {
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    ws = new WebSocket(`${protocol}//${window.location.host}/ws`);

    ws.onopen = () => {
      reconnectAttempts = 0;
      updateStatus('connected', 'Online');
      sendBtn.disabled = false;
    };

    ws.onclose = () => {
      updateStatus('disconnected', 'Disconnected');
      sendBtn.disabled = true;
      if (reconnectAttempts < maxReconnectAttempts) {
        reconnectAttempts++;
        setTimeout(connectWebSocket, 2000 * reconnectAttempts);
      }
    };

    ws.onerror = () => updateStatus('error', 'Error');
    ws.onmessage = (event) => {
      try {
        const data = JSON.parse(event.data);
        handleWebSocketMessage(data);
      } catch (e) {
        console.error('WS Parse error:', e);
      }
    };
  }

  function updateStatus(status, text) {
    const indicator = statusIndicator.querySelector('span:first-child');
    const textEl = statusIndicator.querySelector('span:last-child');
    const colors = {
      connected: 'bg-green-500', disconnected: 'bg-red-500', 
      error: 'bg-red-500', connecting: 'bg-yellow-500'
    };
    indicator.className = `w-1.5 h-1.5 rounded-full ${colors[status] || 'bg-gray-500'}`;
    textEl.textContent = text;
    if (status === 'connected') {
        statusIndicator.classList.add('dark:text-green-400', 'text-green-600', 'border-green-500/20');
        statusIndicator.classList.remove('dark:text-red-400', 'text-red-600', 'border-red-500/20');
    } else {
        statusIndicator.classList.remove('dark:text-green-400', 'text-green-600', 'border-green-500/20');
        statusIndicator.classList.add('dark:text-red-400', 'text-red-600', 'border-red-500/20');
    }
  }

  function handleWebSocketMessage(msg) {
    const type = msg.type;
    const data = msg.data || msg;
    
    switch (type) {
      case 'response':
        if (currentAssistantMessage) {
          const content = currentAssistantMessage.querySelector('.message-content');
          content.innerHTML = formatMessage(data.content || msg.content || '');
          currentAssistantMessage = null;
        } else {
          addMessage('assistant', data.content || msg.content || '');
        }
        addEvent('response', data.content || msg.content);
        break;

      case 'stream':
        if (!currentAssistantMessage) {
          currentAssistantMessage = addMessage('assistant', '');
        }
        const streamDiv = currentAssistantMessage.querySelector('.message-content');
        streamDiv.innerHTML = formatMessage(data.content || msg.content || '');
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
        break;

      case 'thought':
        addEvent('thought', data.content || msg.content);
        break;

      case 'tool_call':
      case 'tool_call_start':
        const toolName = data.tool || data.tool_name || msg.tool || '';
        const toolArgs = data.args || data.arguments || msg.args || {};
        const argsStr = JSON.stringify(toolArgs);
        addEvent('tool_call', `${toolName}(${argsStr.length > 50 ? '...' : argsStr})`);
        break;

      case 'tool_result':
      case 'tool_call_end':
        addEvent('tool_result', truncate(data.result || msg.result || '', 500));
        break;

      case 'error':
        addEvent('error', data.content || msg.content);
        if (currentAssistantMessage) {
          const errMsgDiv = currentAssistantMessage.querySelector('.message-content');
          errMsgDiv.innerHTML = `<span class="text-red-400">Error: ${data.content || msg.content}</span>`;
          currentAssistantMessage = null;
        }
        break;

      case 'status':
        addEvent('status', data.message || data.content || msg.content || '');
        break;

      case 'log':
        addEvent('log', data.content || msg.content);
        break;

      case 'state_sync':
        if (data.theme || msg.theme) applyTheme(data.theme || msg.theme);
        if (data.messages || msg.messages) {
            clearMessages();
            (data.messages || msg.messages).forEach(m => addMessage(m.role, m.content));
        }
        if (data.events || msg.events) {
            clearEventsInternal();
            (data.events || msg.events).forEach(e => addEvent(e.type, e.content));
        }
        break;

      case 'theme_change':
        applyTheme(data.theme || msg.theme);
        break;

      case 'messages_cleared':
        clearMessages();
        break;

      case 'events_cleared':
        clearEventsInternal();
        break;

      default:
        console.log('Event:', type);
    }
  }

  function clearMessages() {
    const welcome = document.getElementById('welcome-message');
    if (welcome) welcome.remove();
    // Clear all children except welcome template or just clear all and let addMessage handle it
    messagesContainer.innerHTML = '';
    // Re-add welcome if empty? No, handled by addMessage
  }

  function clearEventsInternal() {
    eventsList.innerHTML = '';
    const countEl = document.getElementById('event-count');
    if (countEl) countEl.textContent = '0 events';
  }

  function addEvent(type, data) {
    const noEvents = document.getElementById('no-events');
    if (noEvents) noEvents.remove();

    const timestamp = new Date().toISOString();
    const eventDiv = document.createElement('div');
    eventDiv.className = `event-item fade-in p-4 rounded-xl dark:bg-dark-100/50 bg-white border dark:border-white/5 border-gray-200 hover:border-primary/20 transition-all text-sm`;

    const labels = {
      query: 'Input', thought: 'Reasoning', tool_call: 'Action',
      tool_result: 'Result', response: 'Output', error: 'Error', status: 'Update', log: 'Log'
    };

    const colors = {
      query: 'text-primary', thought: 'text-secondary', tool_call: 'text-amber-500',
      tool_result: 'text-success', response: 'text-green-500', error: 'text-danger',
      status: 'text-cyan-400', log: 'dark:text-gray-500 text-gray-400'
    };

    eventDiv.innerHTML = `
      <div class="flex items-center justify-between mb-2">
        <span class="font-black text-[9px] uppercase tracking-widest ${colors[type] || ''}">${labels[type] || type}</span>
        <span class="text-[9px] font-mono opacity-40">${timestamp.slice(-13, -5)}</span>
      </div>
      <div class="dark:text-gray-300 text-gray-700 text-xs font-mono leading-relaxed break-words whitespace-pre-wrap line-clamp-4 hover:line-clamp-none transition-all">${escapeHtml(truncate(String(data || ''), 300))}</div>
    `;

    eventsList.appendChild(eventDiv);
    eventsList.scrollTop = eventsList.scrollHeight;
    
    if (eventsList.children.length > 50) eventsList.children[0].remove();
    const countEl = document.getElementById('event-count');
    if (countEl) countEl.textContent = `${eventsList.children.length} events`;
  }

  function addMessage(role, content) {
    const welcome = document.getElementById('welcome-message');
    if (welcome) welcome.remove();

    const messageDiv = document.createElement('div');
    messageDiv.className = `message-enter flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
    const isUser = role === 'user';
    
    messageDiv.innerHTML = `
      <div class="max-w-[85%] lg:max-w-[70%] ${isUser ? 'bg-primary shadow-premium text-white' : 'dark:bg-dark-50 bg-gray-50 dark:text-gray-100 text-gray-900 border dark:border-white/10 border-gray-200 shadow-sm'} rounded-3xl px-6 py-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[9px] font-black tracking-widest uppercase opacity-60">${isUser ? 'You' : 'Alfred'}</span>
        </div>
        <div class="message-content text-[15px] leading-relaxed">
          ${content ? formatMessage(content) : '<span class="opacity-50 italic">Thinking...</span>'}
        </div>
      </div>
    `;

    messagesContainer.appendChild(messageDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
    return messageDiv;
  }

  function applyTheme(theme) {
    document.documentElement.classList.remove('dark', 'light');
    document.documentElement.classList.add(theme);
  }

  function truncate(str, len) {
    if (!str) return '';
    str = String(str);
    return str.length <= len ? str : str.substring(0, len) + '...';
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function formatMessage(text) {
    if (!text) return '';
    return text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\n/g, '<br>')
      .replace(/`([^`]+)`/g, '<code class="dark:bg-white/10 bg-black/5 px-1 rounded text-primary border border-white/10">$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  }

  chatForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const message = messageInput.value.trim();
    if (!message || !ws || ws.readyState !== WebSocket.OPEN) return;
    addMessage('user', message);
    addEvent('query', message);
    ws.send(JSON.stringify({ type: 'message', content: message }));
    messageInput.value = '';
  });

  themeToggle.addEventListener('click', () => {
    fetch('/api/theme/toggle', { method: 'POST' })
      .then(res => res.json())
      .then(data => applyTheme(data.theme));
  });

  clearEventsBtn.addEventListener('click', () => {
    fetch('/api/clear/events', { method: 'POST' }).then(() => {
        eventsList.innerHTML = `<div id="no-events" class="h-full flex flex-col items-center justify-center opacity-30"><p class="text-xs uppercase tracking-widest">Awaiting Neural Link</p></div>`;
        const countEl = document.getElementById('event-count');
        if (countEl) countEl.textContent = '0 events';
    });
  });

  connectWebSocket();
</script>

<template id="welcome-message-template">
  <div id="welcome-message" class="h-full flex flex-col items-center justify-center text-center fade-in">
    <div class="w-20 h-20 mb-8 rounded-[32px] bg-primary relative flex items-center justify-center shadow-2xl shadow-primary/20">
      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
    </div>
    <h2 class="text-3xl font-black dark:text-white text-gray-900 tracking-tight mb-4">Hello, I'm Alfred.</h2>
    <p class="dark:text-gray-400 text-gray-500 max-w-sm mx-auto text-[15px] leading-relaxed">Your intelligent assistant for automation, browsing, and more. How can I help you today?</p>
  </div>
</template>

{% endblock %}
